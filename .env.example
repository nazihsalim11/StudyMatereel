# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default: Rachel (21m00Tcm4TlvDq8ikWAM). Browse voices at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Backend ───────────────────────────────────────────────────────────────────
# URL the Remotion renderer uses to fetch slide images and audio from FastAPI
BACKEND_URL=http://localhost:8000

# ── Windows tool paths (only needed on Windows) ───────────────────────────────
# Poppler: download from https://github.com/oschwartz10612/poppler-windows/releases
# Extract to C:\poppler — the path below is the default, change if different
POPPLER_PATH=C:\poppler\Library\bin

# LibreOffice: install from https://www.libreoffice.org/download/download/
# The path below is the default Windows install location
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
